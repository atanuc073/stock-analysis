# Telegram bot credentials (get token from @BotFather, chat_id from @userinfobot)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Finnhub free API key (https://finnhub.io) for richer US news/options
FINNHUB_API_KEY=

# Run mode: "broad" (Nifty500 + S&P500) or "watchlist" (curated list only)
RUN_MODE=watchlist

# Top N picks to include in daily report
TOP_N=15

# Forecaster: "prophet" (default), "linear" (lightweight), "timesfm" (best, needs ~2GB deps)
# For timesfm: pip install -r requirements-timesfm.txt   (personal machine only, ~800MB download on first run)
FORECASTER=prophet

# ─────────────────────────────────────────────────────────────────────────────
# Alpaca paper trading (optional — only needed if you use paper_cli.py)
# Sign up free: https://alpaca.markets   (5 min, no SSN, $100k paper cash)
# Then: dashboard → Paper Trading → API Keys → Generate
# ─────────────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
# Set to true ONLY when you want daily_runner to auto-trade. Default: manual via paper_cli.
ENABLE_PAPER_TRADING=false
