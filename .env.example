# Telegram bot credentials (get token from @BotFather, chat_id from @userinfobot)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Finnhub free API key (https://finnhub.io) for richer US news/options
FINNHUB_API_KEY=

# Run mode: "broad" (Nifty500 + S&P500) or "watchlist" (curated list only)
RUN_MODE=watchlist

# Top N picks to include in daily report
TOP_N=15

# Forecaster: "linear" (fast default), "prophet" (medium), "timesfm" (best, needs ~2GB deps)
# For timesfm: pip install -r requirements-timesfm.txt   (personal machine only, ~800MB download on first run)
FORECASTER=linear
